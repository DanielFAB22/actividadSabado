<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    tools:context=".adivina">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <Space
            android:layout_width="match_parent"
            android:layout_height="20sp" />

        <TextView
            android:id="@+id/textview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#00E5FF"
            android:gravity="center"
            android:padding="10dp"
            android:text="JUEGO ADIVINA"
            android:textAppearance="@style/TextAppearance.AppCompat.Large"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="30sp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="20sp" />

        <TextView
            android:id="@+id/v3tvint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Intento 1"
            android:textColor="#00E5FF"
            android:textSize="22sp"
            android:textStyle="italic" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="20sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1F1F1F"
            android:padding="15dp"
            android:elevation="4dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/v3tvpista"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pista: -"
                android:textColor="#FF007F"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/v3etnum"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ems="10"
                android:gravity="center"
                android:hint="00"
                android:inputType="number"
                android:textColor="#00E5FF"
                android:textColorHint="#444444"
                android:textSize="24sp"
                android:backgroundTint="#00E5FF" />

        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="30sp" />

        <Button
            android:id="@+id/v3btnanalizar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:backgroundTint="#00E5FF"
            android:text="Analizar"
            android:textColor="#000000"
            android:textSize="20sp"
            app:cornerRadius="8dp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="15sp" />

        <Button
            android:id="@+id/v3btnnuevo"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:backgroundTint="#1F1F1F"
            android:text="Nuevo"
            android:textColor="#FF007F"
            app:strokeColor="#FF007F"
            app:strokeWidth="2dp"
            android:textSize="20sp"
            app:cornerRadius="8dp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="15sp" />

        <Button
            android:id="@+id/v3btnretronar"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Retornar"
            android:textColor="#777777"
            android:textSize="18sp" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>